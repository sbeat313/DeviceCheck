{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DeviceCheck": {
    "BaseUrl": "https://example-device-api.local/device",
    "CheckIntervalSeconds": 10,
    "BusyRetryDelaySeconds": 3,
    "RequestTimeoutSeconds": 5,
    "Uids": [1001, 1002, 1003]
  }
}
