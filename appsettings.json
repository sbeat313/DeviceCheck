{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DeviceCheck": {
    "BaseUrl": "http://192.168.0.58:5099",
    "CheckIntervalSeconds": 10,
    "BusyRetryDelaySeconds": 3,
    "RequestTimeoutSeconds": 10,
    "Uids": [
      1001,
      1002,
      1003
    ]
  },
  "Notification": {
    "Enabled": true,
    "EndpointUrl": "http://localhost:5058/api/notifications",
    "Recipients": [
      "ops-team@company.local",
      "oncall@company.local"
    ]
  },
  "NLog": {}
}
